{
  "name": "autonomous-operations",
  "version": "0.0.1",
  "description": "Catalog package — operations Services-as-Software defined on the services-as-software primitive + autonomous-finance substrate. Six Services: incident-commander, oncall-handoff-narrator, capacity-planner, slo-budget-tracker, change-window-coordinator, runbook-author. Sibling to autonomous-marketing / autonomous-revenue / autonomous-customer-success / autonomous-finance-services / autonomous-developer-experience / autonomous-startups.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./incident-commander": {
      "types": "./dist/services/incident-commander.d.ts",
      "import": "./dist/services/incident-commander.js"
    },
    "./oncall-handoff-narrator": {
      "types": "./dist/services/oncall-handoff-narrator.d.ts",
      "import": "./dist/services/oncall-handoff-narrator.js"
    },
    "./capacity-planner": {
      "types": "./dist/services/capacity-planner.d.ts",
      "import": "./dist/services/capacity-planner.js"
    },
    "./slo-budget-tracker": {
      "types": "./dist/services/slo-budget-tracker.d.ts",
      "import": "./dist/services/slo-budget-tracker.js"
    },
    "./change-window-coordinator": {
      "types": "./dist/services/change-window-coordinator.d.ts",
      "import": "./dist/services/change-window-coordinator.js"
    },
    "./runbook-author": {
      "types": "./dist/services/runbook-author.d.ts",
      "import": "./dist/services/runbook-author.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-operations#readme"
}
