{
  "name": "autonomous-startups",
  "version": "0.0.1",
  "description": "Catalog package — startup-shaped Services-as-Software defined on the autonomous-finance substrate + services-as-software primitive. Initial: claude-code-feature-build (the v3 worked example). Future: cross-business-model primitives (SaaSProduct / APIProduct / DataProduct / ...).",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./claude-code-feature-build": {
      "types": "./dist/services/claude-code-feature-build.d.ts",
      "import": "./dist/services/claude-code-feature-build.js"
    },
    "./wedge-hypothesis-generator": {
      "types": "./dist/services/wedge-hypothesis-generator.d.ts",
      "import": "./dist/services/wedge-hypothesis-generator.js"
    },
    "./competitor-uncopyability-prober": {
      "types": "./dist/services/competitor-uncopyability-prober.d.ts",
      "import": "./dist/services/competitor-uncopyability-prober.js"
    },
    "./runtime-unit-emitter": {
      "types": "./dist/services/runtime-unit-emitter.d.ts",
      "import": "./dist/services/runtime-unit-emitter.js"
    },
    "./pricing-architect": {
      "types": "./dist/services/pricing-architect.d.ts",
      "import": "./dist/services/pricing-architect.js"
    },
    "./pitch-deck-builder": {
      "types": "./dist/services/pitch-deck-builder.d.ts",
      "import": "./dist/services/pitch-deck-builder.js"
    },
    "./gtm-experiment-runner": {
      "types": "./dist/services/gtm-experiment-runner.d.ts",
      "import": "./dist/services/gtm-experiment-runner.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-startups#readme"
}
