{
  "name": "autonomous-data",
  "version": "0.0.2",
  "description": "Catalog package — data-engineering / analytics Services-as-Software defined on the services-as-software primitive + autonomous-finance substrate. Ships: dbt-model-author, data-quality-incident-triager, metrics-catalog-curator, pipeline-incident-investigator, schema-evolution-planner, ml-model-monitor. Sibling to autonomous-marketing / autonomous-revenue / autonomous-customer-success / autonomous-finance-services / autonomous-developer-experience / autonomous-startups / autonomous-operations / autonomous-people / autonomous-legal.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./dbt-model-author": {
      "types": "./dist/services/dbt-model-author.d.ts",
      "import": "./dist/services/dbt-model-author.js"
    },
    "./data-quality-incident-triager": {
      "types": "./dist/services/data-quality-incident-triager.d.ts",
      "import": "./dist/services/data-quality-incident-triager.js"
    },
    "./metrics-catalog-curator": {
      "types": "./dist/services/metrics-catalog-curator.d.ts",
      "import": "./dist/services/metrics-catalog-curator.js"
    },
    "./pipeline-incident-investigator": {
      "types": "./dist/services/pipeline-incident-investigator.d.ts",
      "import": "./dist/services/pipeline-incident-investigator.js"
    },
    "./schema-evolution-planner": {
      "types": "./dist/services/schema-evolution-planner.d.ts",
      "import": "./dist/services/schema-evolution-planner.js"
    },
    "./ml-model-monitor": {
      "types": "./dist/services/ml-model-monitor.d.ts",
      "import": "./dist/services/ml-model-monitor.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-data#readme"
}
