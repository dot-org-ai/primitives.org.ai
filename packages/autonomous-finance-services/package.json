{
  "name": "autonomous-finance-services",
  "version": "0.0.1",
  "description": "Catalog package — finance Services-as-Software defined on the autonomous-finance substrate + services-as-software primitive. Initial: bookkeeper. Future: controller, AP, AR, tax, treasury, payroll. Sibling to autonomous-customer-success / autonomous-revenue / autonomous-developer-experience.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./bookkeeper": {
      "types": "./dist/services/bookkeeper.d.ts",
      "import": "./dist/services/bookkeeper.js"
    },
    "./controller": {
      "types": "./dist/services/controller.d.ts",
      "import": "./dist/services/controller.js"
    },
    "./ap": {
      "types": "./dist/services/ap.d.ts",
      "import": "./dist/services/ap.js"
    },
    "./ar": {
      "types": "./dist/services/ar.d.ts",
      "import": "./dist/services/ar.js"
    },
    "./tax": {
      "types": "./dist/services/tax.d.ts",
      "import": "./dist/services/tax.js"
    },
    "./treasury": {
      "types": "./dist/services/treasury.d.ts",
      "import": "./dist/services/treasury.js"
    },
    "./payroll": {
      "types": "./dist/services/payroll.d.ts",
      "import": "./dist/services/payroll.js"
    },
    "./audit-prep": {
      "types": "./dist/services/audit-prep.d.ts",
      "import": "./dist/services/audit-prep.js"
    },
    "./expense-policy-enforcer": {
      "types": "./dist/services/expense-policy-enforcer.d.ts",
      "import": "./dist/services/expense-policy-enforcer.js"
    },
    "./cash-runway-projector": {
      "types": "./dist/services/cash-runway-projector.d.ts",
      "import": "./dist/services/cash-runway-projector.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-finance-services#readme"
}
