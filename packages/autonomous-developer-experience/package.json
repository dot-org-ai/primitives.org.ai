{
  "name": "autonomous-developer-experience",
  "version": "0.0.1",
  "description": "Catalog package — developer-experience Services-as-Software defined on the primitive substrate. Initial: api-docs-writer (AST extract → typed reference docs published to GitHub Pages). Future: changelog-generator, sdk-generator, migration-guide-writer, tutorial-author, example-suite-builder. Sibling to autonomous-finance-services / autonomous-customer-success / autonomous-revenue.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./api-docs-writer": {
      "types": "./dist/services/api-docs-writer.d.ts",
      "import": "./dist/services/api-docs-writer.js"
    },
    "./changelog-generator": {
      "types": "./dist/services/changelog-generator.d.ts",
      "import": "./dist/services/changelog-generator.js"
    },
    "./sdk-generator": {
      "types": "./dist/services/sdk-generator.d.ts",
      "import": "./dist/services/sdk-generator.js"
    },
    "./migration-guide-writer": {
      "types": "./dist/services/migration-guide-writer.d.ts",
      "import": "./dist/services/migration-guide-writer.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-developer-experience#readme"
}
