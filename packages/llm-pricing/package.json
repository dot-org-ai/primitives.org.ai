{
  "name": "@primitives/llm-pricing",
  "version": "0.1.0",
  "description": "Canonical LLM model pricing table — keyed by provider/slug/tier, sourced from Vertex/Bedrock/AI-Studio public list prices",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pricing": {
      "import": "./dist/pricing.js",
      "types": "./dist/pricing.d.ts"
    },
    "./lookup": {
      "import": "./dist/lookup.js",
      "types": "./dist/lookup.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "llm",
    "pricing",
    "vertex",
    "bedrock",
    "anthropic",
    "google-ai-studio",
    "gemini",
    "claude",
    "primitives"
  ],
  "license": "MIT"
}
