{
  "name": "@primitives/db-docs-rels",
  "version": "0.1.0",
  "description": "Canonical Drizzle schema for the docs+rels+search+events four-table spine on Neon Postgres + pgvector",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema.js",
      "types": "./dist/schema.d.ts"
    },
    "./custom-types": {
      "import": "./dist/custom-types.js",
      "types": "./dist/custom-types.d.ts"
    },
    "./migrations": {
      "import": "./dist/migrations/index.js",
      "types": "./dist/migrations/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/migrations/*.sql",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.36.0"
  },
  "devDependencies": {
    "drizzle-orm": "^0.36.0"
  },
  "keywords": [
    "drizzle",
    "postgres",
    "neon",
    "pgvector",
    "halfvec",
    "tsvector",
    "embeddings",
    "schema",
    "primitives"
  ],
  "license": "MIT"
}
