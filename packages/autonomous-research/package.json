{
  "name": "autonomous-research",
  "version": "0.0.2",
  "description": "Catalog package — R&D / scientific-research Services-as-Software defined on the services-as-software primitive + autonomous-finance substrate. Ships: literature-review-synthesizer, experiment-protocol-author, manuscript-pre-submission-reviewer, grant-application-author, data-analysis-plan-author, peer-review-coordinator. Sibling to autonomous-marketing / autonomous-revenue / autonomous-customer-success / autonomous-finance-services / autonomous-developer-experience / autonomous-startups / autonomous-operations / autonomous-people / autonomous-legal / autonomous-data / autonomous-product / autonomous-supplychain / autonomous-security.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./literature-review-synthesizer": {
      "types": "./dist/services/literature-review-synthesizer.d.ts",
      "import": "./dist/services/literature-review-synthesizer.js"
    },
    "./experiment-protocol-author": {
      "types": "./dist/services/experiment-protocol-author.d.ts",
      "import": "./dist/services/experiment-protocol-author.js"
    },
    "./manuscript-pre-submission-reviewer": {
      "types": "./dist/services/manuscript-pre-submission-reviewer.d.ts",
      "import": "./dist/services/manuscript-pre-submission-reviewer.js"
    },
    "./grant-application-author": {
      "types": "./dist/services/grant-application-author.d.ts",
      "import": "./dist/services/grant-application-author.js"
    },
    "./data-analysis-plan-author": {
      "types": "./dist/services/data-analysis-plan-author.d.ts",
      "import": "./dist/services/data-analysis-plan-author.js"
    },
    "./peer-review-coordinator": {
      "types": "./dist/services/peer-review-coordinator.d.ts",
      "import": "./dist/services/peer-review-coordinator.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-research#readme"
}
