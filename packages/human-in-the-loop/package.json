{
  "name": "human-in-the-loop",
  "version": "2.3.0",
  "description": "Primitives for integrating human oversight and intervention in AI workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./worker": {
      "import": "./dist/worker.js",
      "types": "./dist/worker.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./request-lifecycle": {
      "import": "./dist/request-lifecycle.js",
      "types": "./dist/request-lifecycle.d.ts"
    },
    "./escalation-engine": {
      "import": "./dist/escalation-engine.js",
      "types": "./dist/escalation-engine.d.ts"
    },
    "./lifecycle-store": {
      "import": "./dist/lifecycle-store.js",
      "types": "./dist/lifecycle-store.d.ts"
    },
    "./lifecycle-store-memory": {
      "import": "./dist/lifecycle-store-memory.js",
      "types": "./dist/lifecycle-store-memory.d.ts"
    },
    "./lifecycle-channel-adapter": {
      "import": "./dist/lifecycle-channel-adapter.js",
      "types": "./dist/lifecycle-channel-adapter.d.ts"
    },
    "./adapters/email-adapter": {
      "import": "./dist/adapters/email-adapter.js",
      "types": "./dist/adapters/email-adapter.d.ts"
    },
    "./adapters/slack-adapter": {
      "import": "./dist/adapters/slack-adapter.js",
      "types": "./dist/adapters/slack-adapter.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ai-functions": "workspace:*",
    "business-as-code": "workspace:*",
    "chat": "^4.27.0",
    "digital-objects": "workspace:*",
    "digital-tasks": "workspace:*",
    "digital-workers": "workspace:*",
    "rpc.do": "*"
  },
  "peerDependencies": {
    "org.ai": "0.0.1"
  },
  "peerDependenciesMeta": {
    "org.ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250124.0",
    "org.ai": "workspace:*",
    "vitest": "3.0.4"
  },
  "keywords": [
    "human",
    "oversight",
    "hitl",
    "primitives"
  ],
  "license": "MIT"
}
