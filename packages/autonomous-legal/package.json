{
  "name": "autonomous-legal",
  "version": "0.0.2",
  "description": "Catalog package — legal Services-as-Software defined on the services-as-software primitive + autonomous-finance substrate. Six Services: contract-reviewer, policy-impact-analyzer, ip-disclosure-triage, litigation-discovery-prep, compliance-attestation-author, regulatory-filing-drafter. Sibling to autonomous-marketing / autonomous-revenue / autonomous-customer-success / autonomous-finance-services / autonomous-developer-experience / autonomous-startups / autonomous-operations.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./contract-reviewer": {
      "types": "./dist/services/contract-reviewer.d.ts",
      "import": "./dist/services/contract-reviewer.js"
    },
    "./policy-impact-analyzer": {
      "types": "./dist/services/policy-impact-analyzer.d.ts",
      "import": "./dist/services/policy-impact-analyzer.js"
    },
    "./ip-disclosure-triage": {
      "types": "./dist/services/ip-disclosure-triage.d.ts",
      "import": "./dist/services/ip-disclosure-triage.js"
    },
    "./litigation-discovery-prep": {
      "types": "./dist/services/litigation-discovery-prep.d.ts",
      "import": "./dist/services/litigation-discovery-prep.js"
    },
    "./compliance-attestation-author": {
      "types": "./dist/services/compliance-attestation-author.d.ts",
      "import": "./dist/services/compliance-attestation-author.js"
    },
    "./regulatory-filing-drafter": {
      "types": "./dist/services/regulatory-filing-drafter.d.ts",
      "import": "./dist/services/regulatory-filing-drafter.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-legal#readme"
}
