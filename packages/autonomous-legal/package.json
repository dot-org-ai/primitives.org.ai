{
  "name": "autonomous-legal",
  "version": "0.0.1",
  "description": "Catalog package — legal Services-as-Software defined on the services-as-software primitive + autonomous-finance substrate. Initial: contract-reviewer, policy-impact-analyzer, ip-disclosure-triage. Sibling to autonomous-marketing / autonomous-revenue / autonomous-customer-success / autonomous-finance-services / autonomous-developer-experience / autonomous-startups / autonomous-operations.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./contract-reviewer": {
      "types": "./dist/services/contract-reviewer.d.ts",
      "import": "./dist/services/contract-reviewer.js"
    },
    "./policy-impact-analyzer": {
      "types": "./dist/services/policy-impact-analyzer.d.ts",
      "import": "./dist/services/policy-impact-analyzer.js"
    },
    "./ip-disclosure-triage": {
      "types": "./dist/services/ip-disclosure-triage.d.ts",
      "import": "./dist/services/ip-disclosure-triage.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-legal#readme"
}
