{
  "name": "autonomous-supplychain",
  "version": "0.0.1",
  "description": "Catalog package — procurement / supply-chain Services-as-Software defined on the services-as-software primitive + autonomous-finance substrate. Ships: vendor-onboarding-runbook, purchase-order-router, inventory-reorder-planner, supplier-risk-monitor, freight-cost-optimizer, customs-compliance-filer, demand-forecast-synthesizer, manufacturing-quality-incident-investigator, supplier-contract-renewal-orchestrator. Sibling to autonomous-marketing / autonomous-revenue / autonomous-customer-success / autonomous-finance-services / autonomous-developer-experience / autonomous-startups / autonomous-operations / autonomous-people / autonomous-legal / autonomous-data / autonomous-product.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./vendor-onboarding-runbook": {
      "types": "./dist/services/vendor-onboarding-runbook.d.ts",
      "import": "./dist/services/vendor-onboarding-runbook.js"
    },
    "./purchase-order-router": {
      "types": "./dist/services/purchase-order-router.d.ts",
      "import": "./dist/services/purchase-order-router.js"
    },
    "./inventory-reorder-planner": {
      "types": "./dist/services/inventory-reorder-planner.d.ts",
      "import": "./dist/services/inventory-reorder-planner.js"
    },
    "./supplier-risk-monitor": {
      "types": "./dist/services/supplier-risk-monitor.d.ts",
      "import": "./dist/services/supplier-risk-monitor.js"
    },
    "./freight-cost-optimizer": {
      "types": "./dist/services/freight-cost-optimizer.d.ts",
      "import": "./dist/services/freight-cost-optimizer.js"
    },
    "./customs-compliance-filer": {
      "types": "./dist/services/customs-compliance-filer.d.ts",
      "import": "./dist/services/customs-compliance-filer.js"
    },
    "./demand-forecast-synthesizer": {
      "types": "./dist/services/demand-forecast-synthesizer.d.ts",
      "import": "./dist/services/demand-forecast-synthesizer.js"
    },
    "./manufacturing-quality-incident-investigator": {
      "types": "./dist/services/manufacturing-quality-incident-investigator.d.ts",
      "import": "./dist/services/manufacturing-quality-incident-investigator.js"
    },
    "./supplier-contract-renewal-orchestrator": {
      "types": "./dist/services/supplier-contract-renewal-orchestrator.d.ts",
      "import": "./dist/services/supplier-contract-renewal-orchestrator.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-supplychain#readme"
}
