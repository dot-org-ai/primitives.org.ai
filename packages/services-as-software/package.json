{
  "name": "services-as-software",
  "version": "2.3.0",
  "description": "Primitives for building AI-powered services that operate as software",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./v3": {
      "import": "./dist/v3/index.js",
      "types": "./dist/v3/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "ai-database": "workspace:*",
    "ai-functions": "workspace:*",
    "business-as-code": "workspace:*",
    "digital-objects": "workspace:*",
    "digital-tools": "workspace:*",
    "digital-workers": "workspace:*",
    "language-models": "workspace:*",
    "zod": "^3.23.0"
  },
  "keywords": [
    "services",
    "software",
    "ai",
    "primitives"
  ],
  "license": "MIT"
}
