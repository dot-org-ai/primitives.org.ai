{
  "name": "autonomous-people",
  "version": "0.0.1",
  "description": "Catalog package — people / HR Services-as-Software defined on the services-as-software primitive + autonomous-finance substrate. Initial: hiring-loop-coordinator, performance-review-narrator, org-design-impact-modeler. Sibling to autonomous-operations / autonomous-marketing / autonomous-revenue / autonomous-customer-success / autonomous-finance-services / autonomous-developer-experience / autonomous-startups / autonomous-legal.",
  "private": true,
  "type": "module",
  "main": "dist/services/index.js",
  "types": "dist/services/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./hiring-loop-coordinator": {
      "types": "./dist/services/hiring-loop-coordinator.d.ts",
      "import": "./dist/services/hiring-loop-coordinator.js"
    },
    "./performance-review-narrator": {
      "types": "./dist/services/performance-review-narrator.d.ts",
      "import": "./dist/services/performance-review-narrator.js"
    },
    "./org-design-impact-modeler": {
      "types": "./dist/services/org-design-impact-modeler.d.ts",
      "import": "./dist/services/org-design-impact-modeler.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "services-as-software": "workspace:*",
    "autonomous-finance": "workspace:*",
    "digital-tools": "workspace:*",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/dot-org-ai/primitives.org.ai/tree/main/packages/autonomous-people#readme"
}
